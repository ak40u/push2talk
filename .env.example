# Push-to-talk hotkey (key name as recognized by 'keyboard' library)
# Examples: f9, scroll lock, pause, right ctrl
HOTKEY=right ctrl

# Audio settings
SAMPLE_RATE=16000

# Recognition language (BCP-47)
LANGUAGE=en-US

# Microphone device index (leave empty for system default)
MICROPHONE_INDEX=

# Max items in recognition history (tray submenu)
HISTORY_SIZE=20

# Default STT engine: openai or yandex
STT_ENGINE=openai

# OpenAI API key (required for openai engine)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Yandex SpeechKit credentials (required for yandex engine)
# SA authorized key file (JSON) — create via: yc iam key create --service-account-name <name> -o sa-key.json
SA_KEY_PATH=sa-key.json
