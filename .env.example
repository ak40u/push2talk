# Yandex SpeechKit credentials
# Get from: https://console.yandex.cloud/
# SA authorized key file (JSON) — create via: yc iam key create --service-account-name <name> -o sa-key.json
SA_KEY_PATH=sa-key.json

# Push-to-talk hotkey (key name as recognized by 'keyboard' library)
# Examples: f9, scroll lock, pause, right ctrl
HOTKEY=right ctrl

# Audio settings
SAMPLE_RATE=16000

# Recognition language
LANGUAGE=ru-RU

# Microphone device index (leave empty for system default)
# Run app and click "List Microphones" in tray to see available devices
MICROPHONE_INDEX=

# Max items in recognition history (tray submenu)
HISTORY_SIZE=20

# OpenAI API key for gpt-4o-mini-transcribe (optional, get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Default STT engine: yandex or openai
STT_ENGINE=yandex
